# Copy this file to .env and fill in the values.

# ── Mapbox ────────────────────────────────────────────────────────────────────
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ── Local Supabase (run `supabase start`, use output values) ──────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<anon key from `supabase status`>
VITE_SUPABASE_SECRET_KEY=<service_role key from `supabase status` — never in browser code>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Production Supabase (Supabase cloud dashboard) ────────────────────────────
PROD_SUPABASE_URL=https://<project-ref>.supabase.co
PROD_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<anon key from Supabase dashboard>
PROD_SUPABASE_SECRET_KEY=<service_role key from Supabase dashboard — never in browser code>
PROD_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ── Google SSO (local dev only) ───────────────────────────────────────────────
# Production: configure the Google provider in Supabase dashboard under
# Authentication > Providers > Google. No env vars needed here for prod.
# Local dev: add OAuth credentials below (never commit them) and add
# http://localhost:54321/auth/v1/callback as an authorised redirect URI
# in your Google Cloud Console OAuth app.
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<your-google-client-id>
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── DEM tile cache (elevation tool) ──────────────────────────────────────────
# Directory where downloaded HRDEM and Copernicus tiles are stored between runs.
# Defaults to ~/.cache/lts_dem if not set.
# DEM_CACHE_DIR=/path/to/your/dem_cache
