# Copy this file to .env and fill in the values.
#
# Production (Supabase cloud dashboard)
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
#
# Google SSO:
# - Production: enable the Google provider in the Supabase dashboard under
#   Authentication > Providers > Google, then add your OAuth credentials there.
#   No additional env vars are required in this file for production.
# - Local dev: add your Google OAuth credentials to .env (never commit them):
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<your-google-client-id>
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=<your-google-client-secret>
#   These are read by supabase/config.toml via env() substitution.
#   Add http://localhost:54321/auth/v1/callback as an authorised redirect URI
#   in your Google Cloud Console OAuth app.
#
# Local development – run `supabase start` and paste the output values below.
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<Publishable key from `supabase status`>
# VITE_SUPABASE_SECRET_KEY=<Secret key from `supabase status` — tests only, never in browser code>
