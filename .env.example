# Copy this file to .env and fill in the values.
#
# Production (Supabase cloud dashboard)
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
#
# Local development – run `supabase start` and paste the output values below.
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<Publishable key from `supabase status`>
# VITE_SUPABASE_SECRET_KEY=<Secret key from `supabase status` — tests only, never in browser code>
#
# E2E tests (Playwright) — run `pnpm test:e2e` against a local dev server.
# Defaults to http://localhost:5173 and the local Supabase instance above.
# PLAYWRIGHT_BASE_URL=http://localhost:5173
# E2E_SUPABASE_URL=http://127.0.0.1:54321
# E2E_SUPABASE_ANON_KEY=<Publishable key from `supabase status`>
