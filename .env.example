# Copy this file to .env and fill in the values.
#
# Production (Supabase cloud dashboard)
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
#
# Google SSO is enabled automatically in production builds (import.meta.env.PROD).
# To activate it, enable the Google provider in the Supabase dashboard under
# Authentication > Providers > Google, then add the OAuth credentials there.
# No additional environment variables are required in this file.
#
# Local development – run `supabase start` and paste the output values below.
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<Publishable key from `supabase status`>
# VITE_SUPABASE_SECRET_KEY=<Secret key from `supabase status` — tests only, never in browser code>
