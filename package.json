{
  "name": "ladysmithtrailstewards",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "node scripts/db-reset.js",
    "db:migrate": "node scripts/db-migrate.js",
    "db:status": "supabase status",
    "db:studio": "open http://127.0.0.1:54323",
    "db:types": "supabase gen types typescript --local --schema public > src/lib/supabase/database.types.ts",
    "db:policies": "node scripts/extract-db-policies.js",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "prepare": "husky",
    "git-commit-doc": "node scripts/git-commit-doc.js",
    "git-prepr-doc": "node scripts/git-prepr-doc.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/cabin": "^5.2.8",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/josefin-sans": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.20.0",
    "mapbox-gl-draw-snap-mode": "^0.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.2.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supabase": "^2.79.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  }
}
