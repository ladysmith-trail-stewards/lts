#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"

run_script() {
	if command -v pnpm >/dev/null 2>&1; then
		pnpm run "$1"
	else
		npm run "$1"
	fi
}

echo "Running integration tests before push..."
echo "Generating Supabase types and ensuring they're committed..."
run_script db:types
if [ -n "$(git status --porcelain src/lib/supa-client/database.types.ts)" ]; then
	echo "database.types.ts changed. Please commit generated types before pushing."
	git --no-pager diff -- src/lib/supa-client/database.types.ts || true
	exit 1
fi

echo "Running integration tests before push..."
run_script test:integration